{
  "gpt_sovits": {
    "mode": "local",
    "version": "v2Pro",
    "language": "ja",
    "gpu": "0",
    "asr_model_size": "large-v3",
    "asr_precision": "float16",
    "api_host": "127.0.0.1",
    "api_port": 9880,
